# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=https://sixth-sense.app

# Resend (transactional email)
RESEND_API_KEY=re_your_key

# hCaptcha (signup / take submission bot protection)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-site-key
HCAPTCHA_SECRET=your-secret

# Cron auth — Vercel sends this as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=long-random-string

# HMAC secret for signed unsubscribe links — REQUIRED in prod
UNSUBSCRIBE_SECRET=long-random-string
